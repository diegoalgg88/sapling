# Sapling Environment Variables Example
# Copy this file to .env and fill in your API keys
# Only uncomment the providers you plan to use

# =============================================================================
# Anthropic (Native)
# =============================================================================
# Get your API key from: https://console.anthropic.com
# Models: claude-sonnet-4-5, claude-opus-4-6, claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_AUTH_TOKEN=sk-ant-xxx  # Alternative alias

# =============================================================================
# MiniMax (Gateway - requires base-url)
# =============================================================================
# Get your API key from: https://api.minimax.io
# Models: MiniMax-M2.5, minimax-text-01
# Note: Must also set base-url via CLI: sapling auth set minimax --base-url https://api.minimax.io/anthropic
MINIMAX_API_KEY=sk-mm-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# NVIDIA NIM (Gateway)
# =============================================================================
# Get your API key from: https://build.nvidia.com/explore
# Models: qwen/qwen3-coder-480b, meta/llama-3.1-70b, mistralai/mistral-large
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1  # Auto-configured

# =============================================================================
# Qwen / Z.AI (Gateway - OAuth Automatic)
# =============================================================================
# OAuth: Automatically loaded from ~/.qwen/oauth_creds.json ⭐
# Alternative: Get API key from: https://platform.z.ai
# Models: coder-model, qwen-2.5-72b, qwen-max
# Z_AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Alternative alias
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # Auto-configured

# =============================================================================
# Gemini (Gateway - OAuth Automatic)
# =============================================================================
# OAuth: Automatically loaded from ~/.gemini/oauth_creds.json ⭐
# Alternative: API key (if not using OAuth)
# Models: gemini-2.0-flash, gemini-2.5-pro, gemma-3b, gemma-7b
# GEMINI_API_KEY=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  # Auto-configured

# =============================================================================
# Sapling Configuration
# =============================================================================
# Default model (aliases: sonnet, opus, haiku, or full model names)
# SAPLING_MODEL=claude-sonnet-4-5

# Default backend (sdk or openai)
# SAPLING_BACKEND=openai

# Maximum turns per run
# SAPLING_MAX_TURNS=200

# Context window size
# SAPLING_CONTEXT_WINDOW=200000

# =============================================================================
# Usage Examples
# =============================================================================
#
# 1. Economic (OAuth - Free):
#    sapling run "Fix bug" --model coder-model
#    sapling run "Explain code" --model gemini-2.0-flash
#
# 2. Balanced (NVIDIA):
#    sapling run "Add tests" --model qwen/qwen3-coder-480b-a35b-instruct --backend sdk
#
# 3. Premium (Anthropic):
#    sapling run "Refactor auth" --model claude-opus-4-6
#
# =============================================================================
